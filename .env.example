# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aisdr

# Auth
JWT_SECRET=your-secret-here
JWT_EXPIRES_IN=7d

# Claude AI
ANTHROPIC_API_KEY=sk-ant-...

# Apollo.io
APOLLO_API_KEY=...

# Unipile (LinkedIn)
UNIPILE_API_KEY=...
UNIPILE_DSN=...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_AGENCY=price_...

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=...
SMTP_PASS=...
SMTP_FROM=SDR Agent <noreply@yourdomain.com>

# Redis
REDIS_URL=redis://localhost:6379

# App
PORT=3001
BACKEND_URL=https://api.yourdomain.com
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Calendly (for auto-reply booking links)
CALENDLY_URL=https://calendly.com/yourname/30min

# IMAP (for reply detection and bounce handling — same account as SMTP)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
# Uses SMTP_USER and SMTP_PASS for auth

# People Data Labs (lead database — 3B+ contacts)
PDL_API_KEY=

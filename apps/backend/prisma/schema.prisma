  threadId          String?

  aiGenerated Boolean     @default(false)
  demo        Boolean     @default(false)
  replyClass  ReplyClass?

  // M28-1: шаблон, из которого собрано письмо (если compose шёл по шаблону) — для аудита/трассировки.
  templateId String?
  template   EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  // M28-1: ключ идемпотентности compose/draft/send — защита от двойного клика/ретрая (один Email+Activity на ключ).
  idempotencyKey String?


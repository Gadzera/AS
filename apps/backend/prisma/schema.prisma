// ===== AI-атрибуты и кредиты (§4, §15 ТЗ) =====

model CreditBalance {
  id    String       @id @default(cuid())
  orgId String       @unique
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  monthlyCredits   Int       @default(100)
  purchasedCredits Int       @default(0)
  usedCredits      Int       @default(0)
  remainingCredits Int       @default(100)
  periodStart      DateTime  @default(now())
  periodEnd        DateTime?

  transactions CreditTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@map("credit_balances")
}

model CreditTransaction {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  balanceId String
  balance   CreditBalance @relation(fields: [balanceId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation("CreditTransactionActor", fields: [userId], references: [id], onDelete: SetNull)

  aiRunId String? @unique
  aiRun   AiRun?  @relation("AiRunCreditTransaction", fields: [aiRunId], references: [id], onDelete: SetNull)

  // M16-1: hardening — source(enum) + generic idempotency + links на bulk/reply.
  source         CreditSource @default(MANUAL)
  idempotencyKey String?      @unique // дедуп списаний (ОБЯЗАТЕЛЕН для product-debits); NULL допускают много (ручные adjustment)
  bulkRunId      String?
  replyDraftId   String?

  type         CreditTransactionType
  amount       Int
  balanceAfter Int
  reason       String?
  metadata     Json?

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([balanceId])
  @@index([userId])
  @@index([type])
  @@index([source])
  @@index([orgId, createdAt]) // M16-1: period-aware reconcile
  @@index([createdAt])
  @@map("credit_transactions")
}

model AiRun {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  attributeId String
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  recordId String
  record   Record @relation(fields: [recordId], references: [id], onDelete: Cascade)

  valueId String?
  value   Value?  @relation(fields: [valueId], references: [id], onDelete: SetNull)

  bulkRunId String?
  bulkRun   AiBulkRun? @relation(fields: [bulkRunId], references: [id], onDelete: SetNull)

  requestedById String?
  requestedBy   User?   @relation("AiRunRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)

  aiType      AttributeAiType
  status      AiRunStatus @default(PENDING)
  creditsCost Int         @default(0)

  input      Json?
  output     Json?
  outputText String? @db.Text
  error      String? @db.Text

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creditTransaction CreditTransaction? @relation("AiRunCreditTransaction")

  // M25-1: идемпотентность AI-run (для auto-rerun M25-2: auto-rerun:<rec>:<attr>:<sourceActivityId>).
  // NULL допускает множество ручных run'ов; заданный ключ — ровно один run на событие.
  idempotencyKey String?

  @@unique([orgId, idempotencyKey])
  @@index([orgId])
  @@index([attributeId])
  @@index([recordId])
  @@index([bulkRunId])
  @@index([requestedById])
  @@index([status])
  @@index([createdAt])
  @@map("ai_runs")
}

model AiBulkRun {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  attributeId String
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  viewId String?
  view   View?   @relation(fields: [viewId], references: [id], onDelete: SetNull)

  requestedById String?
  requestedBy   User?   @relation("AiBulkRunRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)

  status       AiRunStatus @default(PENDING)
  totalCount   Int         @default(0)
  pendingCount Int         @default(0)
  successCount Int         @default(0)
  failedCount  Int         @default(0)
  // M29-1: строки, пропущенные guard'ом защиты ручного значения (source=MANUAL) — НЕ ошибка, отдельный счётчик для честного partial.
  skippedCount Int         @default(0)

  creditsReserved Int @default(0)
  creditsSpent    Int @default(0)

  filters   Json?
  recordIds Json?
  error     String? @db.Text

  // M25-1 (правка #6): идемпотентность создания bulk-run. Повтор POST с тем же ключом → тот же AiBulkRun
  // (без второго reserve/debit). NULL допускает множество (legacy/без ключа).
  clientRequestId String?

  runs AiRun[]

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([orgId, clientRequestId])
  @@index([orgId])
  @@index([attributeId])
  @@index([viewId])
  @@index([requestedById])
  @@index([status])
  @@index([createdAt])
  @@map("ai_bulk_runs")
}

// Решение ревью по конкретному AI-значению (M9.3): approve / reject / edit низкоуверенных
// AI-значений. Standalone (без relation-полей) — связи по recordId/attributeId логические.
model ValueReview {
  id          String         @id @default(cuid())
  orgId       String
  recordId    String
  attributeId String
  status      AiReviewStatus
  confidence  Int?           // снимок confidence на момент решения (confidenceSnapshot, M9.8)
  // снимки значения на момент решения (M9.8 audit): чтобы после reject/edit provenance показывал,
  // ЧТО именно было решено. approve: before==after; reject: after=null; edit: after=ручное значение.
  valueBefore String?        @db.Text
  valueAfter  String?        @db.Text
  // версия решения: чтобы новый AI re-run того же поля не скрывался старым решением (M9.3).
  // valueFingerprint = `${aiRunId|∅}|${valueAfter|∅}|${confidence|∅}`; aiRunId — если значение из AI-run.
  aiRunId          String?
  valueFingerprint String?
  note        String?        @db.Text
  decidedById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([recordId, attributeId, valueFingerprint])
  @@index([orgId])
  @@index([attributeId])
  @@index([status])
  @@map("crm_value_reviews")
}


  scope      SavedPromptScope @default(PERSONAL)
  title      String
  body       String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  archivedAt DateTime?

  @@index([orgId, scope, archivedAt])
  @@index([orgId, userId])
  @@map("assistant_saved_prompts")
}

// M26-2: внутренний черновик письма (DRAFT_EMAIL apply). НЕ отправляется наружу — честный статус
// «sending unavailable until mailbox/SMTP connected». leadId/recordId — мягкие ссылки (валидируются на apply).

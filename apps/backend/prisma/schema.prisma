generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String
  role         Role          @default(MEMBER)
  orgId        String?
  org          Organization? @relation(fields: [orgId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  campaigns    Campaign[]
}

model Organization {
  id               String         @id @default(cuid())
  name             String
  plan             Plan           @default(STARTER)
  stripeCustomerId String?
  stripeSubId      String?
  leadsLimit       Int            @default(500)
  referralCode     String?        @unique
  referredByOrgId  String?
  bonusLeads       Int            @default(0)
  users            User[]
  leads            Lead[]
  campaigns        Campaign[]
  apiKeys          ApiKey[]
  smtpAccounts     SmtpAccount[]
  webhooks         Webhook[]
  templates        Template[]
  notifications    Notification[]
  createdAt        DateTime       @default(now())
}

model ApiKey {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  service   String
  keyValue  String
  createdAt DateTime     @default(now())

  @@index([orgId])
}

// Multiple sending accounts per org — enables inbox rotation
model SmtpAccount {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  name      String       // Display name e.g. "john@acme.com"
  host      String
  port      Int          @default(587)
  user      String
  pass      String
  fromName  String?
  fromEmail String
  active    Boolean      @default(true)
  // Warm-up tracking
  createdAt DateTime     @default(now())
  messages  Message[]

  @@index([orgId])
}

// Zapier / Make / custom webhooks
model Webhook {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  name      String
  url       String
  events    String[]     // e.g. ["reply", "open", "bounce", "unsubscribe"]
  active    Boolean      @default(true)
  secret    String?
  createdAt DateTime     @default(now())

  @@index([orgId])
}

model Lead {
  id               String         @id @default(cuid())
  orgId            String
  org              Organization   @relation(fields: [orgId], references: [id])
  firstName        String
  lastName         String
  email            String?
  emailValid       EmailValidity  @default(UNKNOWN)
  linkedinUrl      String?
  title            String?
  company          String?
  companySize      String?
  industry         String?
  country          String?
  city             String?
  website          String?
  score            Int            @default(0)
  status           LeadStatus     @default(NEW)
  source           String?
  apolloId         String?
  enriched         Boolean        @default(false)
  bounced          Boolean        @default(false)
  unsubscribeToken String?        @unique
  notes            String?
  messages         Message[]
  campaignLeads    CampaignLead[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([orgId])
  @@index([orgId, status])
  @@index([email])
}

model Campaign {
  id             String         @id @default(cuid())
  orgId          String
  org            Organization   @relation(fields: [orgId], references: [id])
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  name           String
  status         CampaignStatus @default(DRAFT)
  channel        Channel        @default(EMAIL)
  targetIndustry String?
  targetCountry  String?
  targetSize     String?
  dailyLimit           Int            @default(50)
  abTestEnabled        Boolean        @default(false)
  bannerbearTemplateId String?
  sequences      Sequence[]
  campaignLeads  CampaignLead[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([orgId])
  @@index([orgId, status])
}

model Sequence {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  stepNumber Int
  delayDays  Int      @default(0)
  subject    String?
  body       String   @db.Text
  // A/B variant
  subjectB   String?
  bodyB      String?  @db.Text
  channel    Channel  @default(EMAIL)
  createdAt  DateTime @default(now())

  @@index([campaignId, stepNumber])
}

model CampaignLead {
  id            String     @id @default(cuid())
  campaignId    String
  campaign      Campaign   @relation(fields: [campaignId], references: [id])
  leadId        String
  lead          Lead       @relation(fields: [leadId], references: [id])
  currentStep   Int        @default(0)
  status        LeadStatus @default(NEW)
  nextSendAt    DateTime?
  abVariant     String?
  createdAt     DateTime   @default(now())

  @@unique([campaignId, leadId])
  @@index([nextSendAt])
  @@index([leadId, status])
}

model Message {
  id            String       @id @default(cuid())
  leadId        String
  lead          Lead         @relation(fields: [leadId], references: [id])
  smtpAccountId String?
  smtpAccount   SmtpAccount? @relation(fields: [smtpAccountId], references: [id])
  direction     Direction
  channel       Channel
  subject       String?
  body          String       @db.Text
  aiGenerated   Boolean      @default(false)
  abVariant     String?
  replyClass    ReplyClass?
  smtpMessageId String?
  bounced       Boolean      @default(false)
  sentAt        DateTime?
  openedAt      DateTime?
  clickedAt     DateTime?
  clicks        Int          @default(0)
  repliedAt     DateTime?
  createdAt     DateTime     @default(now())

  @@index([leadId])
  @@index([smtpMessageId])
  @@index([direction, sentAt])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum Plan {
  STARTER
  GROWTH
  AGENCY
}

enum LeadStatus {
  NEW
  CONTACTED
  REPLIED
  HOT
  CONVERTED
  LOST
  UNSUBSCRIBED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum Channel {
  EMAIL
  LINKEDIN
}

enum Direction {
  OUTBOUND
  INBOUND
}

enum ReplyClass {
  INTERESTED
  NOT_INTERESTED
  FOLLOW_UP
  UNSUBSCRIBE
}

enum EmailValidity {
  UNKNOWN
  VALID
  INVALID
  DISPOSABLE
  NO_MX
}

// Reusable email / LinkedIn message templates
model Template {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  name      String
  subject   String?
  body      String       @db.Text
  channel   Channel      @default(EMAIL)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([orgId])
}

model Notification {
  id        String           @id @default(cuid())
  orgId     String
  org       Organization     @relation(fields: [orgId], references: [id])
  type      NotificationType
  title     String
  body      String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([orgId, read])
  @@index([orgId, createdAt])
}

enum NotificationType {
  REPLY_RECEIVED
  CAMPAIGN_COMPLETED
  HOT_LEAD
  UPGRADE_NUDGE
  ONBOARDING
  REFERRAL_JOINED
}

model OnboardingProgress {
  id              String   @id @default(cuid())
  orgId           String   @unique
  smtpAdded       Boolean  @default(false)
  firstLeadAdded  Boolean  @default(false)
  firstCampaign   Boolean  @default(false)
  firstSent       Boolean  @default(false)
  firstReply      Boolean  @default(false)
  completedAt     DateTime?
  createdAt       DateTime @default(now())
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Users & Auth
model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String
  role         Role          @default(MEMBER)
  orgId        String?
  org          Organization? @relation(fields: [orgId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  campaigns    Campaign[]
}

model Organization {
  id               String     @id @default(cuid())
  name             String
  plan             Plan       @default(STARTER)
  stripeCustomerId String?
  stripeSubId      String?
  leadsLimit       Int        @default(500)
  users            User[]
  leads            Lead[]
  campaigns        Campaign[]
  apiKeys          ApiKey[]
  createdAt        DateTime   @default(now())
}

model ApiKey {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  service   String // apollo | unipile | smtp
  keyValue  String
  createdAt DateTime     @default(now())
}

// Leads
model Lead {
  id               String         @id @default(cuid())
  orgId            String
  org              Organization   @relation(fields: [orgId], references: [id])
  firstName        String
  lastName         String
  email            String?
  linkedinUrl      String?
  title            String?
  company          String?
  companySize      String?
  industry         String?
  country          String?
  city             String?
  website          String?
  score            Int            @default(0)
  status           LeadStatus     @default(NEW)
  source           String?
  apolloId         String?
  enriched         Boolean        @default(false)
  bounced          Boolean        @default(false)
  unsubscribeToken String?        @unique
  notes            String?
  messages         Message[]
  campaignLeads    CampaignLead[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

// Campaigns
model Campaign {
  id             String         @id @default(cuid())
  orgId          String
  org            Organization   @relation(fields: [orgId], references: [id])
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  name           String
  status         CampaignStatus @default(DRAFT)
  channel        Channel        @default(EMAIL)
  targetIndustry String?
  targetCountry  String?
  targetSize     String?
  dailyLimit     Int            @default(50)
  sequences      Sequence[]
  campaignLeads  CampaignLead[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Sequence {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  stepNumber Int
  delayDays  Int      @default(0)
  subject    String?
  body       String   @db.Text
  channel    Channel  @default(EMAIL)
  createdAt  DateTime @default(now())
}

model CampaignLead {
  id          String     @id @default(cuid())
  campaignId  String
  campaign    Campaign   @relation(fields: [campaignId], references: [id])
  leadId      String
  lead        Lead       @relation(fields: [leadId], references: [id])
  currentStep Int        @default(0)
  status      LeadStatus @default(NEW)
  nextSendAt  DateTime?
  createdAt   DateTime   @default(now())

  @@unique([campaignId, leadId])
}

model Message {
  id          String      @id @default(cuid())
  leadId      String
  lead        Lead        @relation(fields: [leadId], references: [id])
  direction   Direction
  channel     Channel
  subject     String?
  body        String      @db.Text
  aiGenerated Boolean     @default(false)
  replyClass  ReplyClass?
  smtpMessageId String?   // SMTP Message-ID header for IMAP reply matching
  bounced     Boolean     @default(false)
  sentAt      DateTime?
  openedAt    DateTime?
  repliedAt   DateTime?
  createdAt   DateTime    @default(now())
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum Plan {
  STARTER
  GROWTH
  AGENCY
}

enum LeadStatus {
  NEW
  CONTACTED
  REPLIED
  HOT
  CONVERTED
  LOST
  UNSUBSCRIBED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum Channel {
  EMAIL
  LINKEDIN
}

enum Direction {
  OUTBOUND
  INBOUND
}

enum ReplyClass {
  INTERESTED
  NOT_INTERESTED
  FOLLOW_UP
  UNSUBSCRIBE
}

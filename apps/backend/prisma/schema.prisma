// M16-1: источник транзакции (enum — без разнобоя ai-attribute/ai_attribute).
enum CreditSource {
  AI_ATTRIBUTE
  BULK_RUN
  AUTO_RESPONSE
  RESEARCH
  ENRICHMENT
  STRIPE
  GRANT
  PURCHASE
  ADJUSTMENT
  MANUAL
  WORKFLOW_AI // M17-4: кредит потрачен AI-блоком workflow-автоматизации (видно отдельно в Billing/Usage)
  CALL_INSIGHT // M19-1: кредит потрачен прогоном insight-шаблона над транскриптом звонка (1 cr/секция)
}

// ───────────────────────── M21 Permissions / RBAC (модуль 17, S345–S356) ─────────────────────────
// 4 уровня доступа (порядок = сила). FULL = управление сущностью + её правами, НЕ billing/security/members.
enum AccessLevel {
  NONE
  READ
  READ_WRITE
  FULL
}

// Область гранта: точнее перекрывает шире (Individual > Team > Workspace).
enum PermissionScope {
  WORKSPACE
  TEAM
  INDIVIDUAL
}

// Виды сущностей, на которые выдаётся доступ.
enum EntityKind {
  OBJECT
  LIST
  DASHBOARD
  WORKFLOW
  SEQUENCE
}

// Единый ACL. subjectKey: 'workspace' | 'team:<teamId>' | 'user:<userId>' (правка GPT #1 — unique НЕ на nullable).
// entityKey: '*' (дефолт для всего вида) | '<entityId>'. Системный fallback после всех lookup = NONE (правка #2).
model PermissionGrant {
  id          String          @id @default(cuid())
  orgId       String
  scope       PermissionScope
  subjectKey  String
  entityKind  EntityKind
  entityKey   String
  level       AccessLevel
  updatedById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([orgId, scope, subjectKey, entityKind, entityKey])
  @@index([orgId, entityKind, entityKey])
  @@index([orgId, subjectKey])
  @@map("crm_permission_grants")
}

// ───────────────────────── M21-2 Teams / Automation grants / Expert groups ─────────────────────────
// Команда. isExternal=true → expert access group (S356): дефолт NONE, только явные гранты.
model Team {
  id          String       @id @default(cuid())
  orgId       String
  name        String
  description String?
  color       String?
  isExternal  Boolean      @default(false)
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  members     TeamMember[]

  @@unique([orgId, name])
  @@index([orgId])
  @@map("crm_teams")
}

model TeamMember {
  id        String   @id @default(cuid())
  orgId     String
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([teamId, userId])
  @@index([orgId])
  @@index([userId])
  @@map("crm_team_members")
}

// Automation-грант (S352): доступ воркфлоу к сущности (READ|READ_WRITE), независимо от триггерящего юзера.
model AutomationGrant {
  id          String      @id @default(cuid())
  orgId       String
  workflowId  String
  workflow    Workflow    @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  entityKind  EntityKind
  entityKey   String // '*' (kind default) | '<entityId>'
  level       AccessLevel // READ | READ_WRITE
  updatedById String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([orgId, workflowId, entityKind, entityKey])
  @@index([orgId, workflowId])
  @@map("crm_automation_grants")
}

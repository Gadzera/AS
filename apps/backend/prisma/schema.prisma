// ─── M26 Ask AISDR (модуль 10): per-user чаты ассистента + сохранённые pending-действия ───

enum AssistantMessageRole {
  USER
  ASSISTANT
}

enum AskActionKind {
  CREATE_TASK
  UPDATE_RECORD
  DRAFT_EMAIL
  NAVIGATE
}

enum AskActionStatus {
  PENDING
  APPLIED
  DISMISSED
}

// M26-1: чат-тред ассистента. Per-user (org-scoped), без шаринга. Recent chat на homepage/sidebar — из чатов владельца.
model AssistantChat {
  id         String   @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("AssistantChatUser", fields: [userId], references: [id], onDelete: Cascade)
  title      String   @default("New chat")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  archivedAt DateTime?
  messages   AssistantMessage[]
  actions    AskAction[]

  @@index([orgId, userId, archivedAt])
  @@map("assistant_chats")
}

// M26-1: сообщение треда. citations — RBAC-aware снимок на момент генерации (deep-link re-check на открытии).
model AssistantMessage {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  chatId      String
  chat        AssistantChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role        AssistantMessageRole
  content     String       @db.Text
  citations   Json?
  generatedBy String? // deepseek | anthropic | demo
  createdAt   DateTime     @default(now())
  actions     AskAction[]

  @@index([chatId, createdAt])
  @@map("assistant_messages")
}

// M26-1/M26-2: сохранённое pending-действие (канонический JSON, НЕ пересборка из текста). Apply-эндпоинт — M26-2.
model AskAction {
  id             String   @id @default(cuid())
  orgId          String
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  chatId         String
  chat           AssistantChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  messageId      String
  message        AssistantMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId         String // для кого действие (RBAC на apply)
  kind           AskActionKind
  payload        Json   // канонический JSON (task/diff/draft/href)
  status         AskActionStatus @default(PENDING)
  idempotencyKey String?
  appliedAt      DateTime?
  appliedResult  Json?
  createdAt      DateTime @default(now())

  @@unique([orgId, idempotencyKey])
  @@index([chatId])
  @@map("assistant_actions")
}

// M26-2: библиотека сохранённых промптов. PERSONAL — личные (default); WORKSPACE — общие
// (создавать/править/удалять может только OWNER/ADMIN, переиспользовать — все в org).
enum SavedPromptScope {
  PERSONAL
  WORKSPACE
}

model SavedPrompt {
  id         String   @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
